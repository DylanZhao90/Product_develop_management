# ============================================
# PDM Frontend — Environment Variables
# ============================================
# Copy this file to .env and fill in values
# cp .env.example .env

# API base URL (empty means same origin / proxy)
# In dev, Vite proxies /api -> http://localhost:8000
VITE_API_BASE_URL=

# Auth mode: 'cookie' (httpOnly, recommended) or 'token' (localStorage, legacy)
VITE_AUTH_MODE=cookie

# Application title
VITE_APP_TITLE=PDM - Product Development Management
